<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Favorites - Dogboard</title>
    <style>
        body {
            font-family: sans-serif;
            background-color: #f0f0f0;
            margin: 0;
            padding: 20px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }
        .card {
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .card img {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }
        .btn {
            padding: 10px 15px;
            text-decoration: none;
            background: #3498db;
            color: white;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>My Favorite Dogs</h1>
        <a href="/" class="btn">Back to Home</a>
    </div>
    
    <div class="grid">
        <% favorites.forEach(dog => { %>
            <div class="card">
                <img src="<%= dog.url %>" alt="Favorite Dog">
            </div>
        <% }); %>
    </div>
</body>
</html>